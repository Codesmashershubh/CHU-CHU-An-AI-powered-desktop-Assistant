{
  "name": "chu-chu",
  "version": "1.0.0",
  "description": "Chu Chu — a free, 8GB-laptop-optimized AI OS assistant.",
  "author": "Chu Chu",
  "license": "MIT",
  "private": true,
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "electron:dev": "concurrently -k -n VITE,ELECTRON -c blue,magenta \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^41.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "optionalDependencies": {
    "playwright": "^1.49.0"
  }
}
