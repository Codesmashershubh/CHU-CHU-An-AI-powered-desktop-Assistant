# Copy to .env. Vite only exposes variables prefixed VITE_ to the renderer —
# see https://vite.dev/guide/env-and-mode for why that prefix matters.

# Your deployed Render backend URL (no trailing slash). For local backend dev:
# VITE_API_BASE_URL=http://localhost:8000
VITE_API_BASE_URL=https://your-service-name.onrender.com

# Must match APP_SHARED_SECRET on the backend exactly — copy it from
# Render -> your service -> Environment tab. See docs/DEPLOYMENT.md.
VITE_APP_SHARED_SECRET=
