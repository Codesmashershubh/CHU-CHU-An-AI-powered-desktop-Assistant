# Copy to .env for local development. On Render, set these as Environment
# Variables in the dashboard (or via render.yaml) instead of committing a .env file.

# --- Core ---------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=info
APP_NAME=Chu Chu

# --- CORS -----------------------------------------------------------------------
# "*" by default — safe here because the real access boundary is
# APP_SHARED_SECRET below, not CORS (see core/config.py for why). Narrow this
# to specific origins only if you also ship a web build you want to restrict.
CORS_ORIGINS=*

# --- Access control -----------------------------------------------------------
# Recommended once deployed: a random string only your Electron app knows.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_SHARED_SECRET=

RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# --- AI providers ---------------------------------------------------------------
# Get a free Groq key (no credit card) at https://console.groq.com/keys
# This is the only key you strictly need to get Chu Chu talking.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Optional fallback #1 — free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional fallback #2 — free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Order to try providers in. Only ones with a key set are actually used.
AI_PROVIDER_ORDER=groq,gemini,openrouter
AI_TEMPERATURE=0.6
AI_MAX_TOKENS=1024
AI_REQUEST_TIMEOUT_SECONDS=45

# --- Web search (optional) ------------------------------------------------------
# Free key (1,000 searches/month, no card) at https://app.tavily.com
TAVILY_API_KEY=

# --- Database --------------------------------------------------------------------
# Default: local SQLite file — zero setup, but resets on every Render free-tier
# redeploy/restart. For notes/reminders that actually persist, create a free
# Postgres database (Neon.tech is the easiest — scale-to-zero, no expiry) and
# paste its connection string here. See docs/DEPLOYMENT.md.
DATABASE_URL=sqlite+aiosqlite:///./data/chuchu.db

ASSISTANT_NAME=Chu Chu
